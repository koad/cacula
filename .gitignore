# Private keys — never commit
id/ed25519
id/ecdsa
id/rsa
id/dsa

# GPG revocation certificate — store offline, never commit
id/gpg-revocation.asc

# Entity GPG keyring — private keys, never commit
keyring/

# SSL private keys
ssl/master-curve.pem
ssl/device-curve.pem
ssl/relay-curve.pem
ssl/session.pem

# Secrets — .env is committed (config only), .credentials is not (secrets only)
.credentials

# Dependencies
node_modules/

# Logs
*.log
logs/*.log

# Runtime
proc/
var/
home/cacula/.cache/
home/*/.bash_history
home/*/.zsh_history
home/*/.local/

# macOS
.DS_Store

# Editor
.vscode/
*.swp

# Flight plans — ephemeral dispatch artifacts (durable record is commit trailer)
flight-plans/

# Claude Code harness artifacts (regenerated per session)
.claude.json
.claude/
mcp-needs-auth-cache.json
